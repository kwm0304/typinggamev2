{
  "openapi": "3.1.1",
  "info": {
    "title": "server | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:5262"
    }
  ],
  "paths": {
    "/api/{controller}/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "parameters": [
          {
            "name": "controller",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/{controller}/github/login": {
      "get": {
        "tags": [
          "Auth"
        ],
        "parameters": [
          {
            "name": "controller",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/{controller}/github/callback": {
      "get": {
        "tags": [
          "Auth"
        ],
        "parameters": [
          {
            "name": "controller",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/{controller}/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "parameters": [
          {
            "name": "controller",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignupDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/SignupDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/SignupDTO"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/{controller}": {
      "post": {
        "tags": [
          "Game"
        ],
        "parameters": [
          {
            "name": "controller",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GameConfigurationDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/GameConfigurationDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/GameConfigurationDTO"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/GameTextDTO"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GameTextDTO"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/GameTextDTO"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "GameConfigurationDTO": {
        "type": "object",
        "properties": {
          "hasPunctuation": {
            "type": "boolean"
          },
          "hasNumbers": {
            "type": "boolean"
          },
          "isTimed": {
            "type": "boolean"
          },
          "isWords": {
            "type": "boolean"
          },
          "isQuote": {
            "type": "boolean"
          },
          "isCustom": {
            "type": "boolean"
          },
          "quoteSize": {
            "type": [
              "null",
              "string"
            ]
          },
          "gameTextLength": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "gameTimeLengthSeconds": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "GameTextDTO": {
        "required": [
          "text"
        ],
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          }
        }
      },
      "LoginRequest": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "twoFactorCode": {
            "type": [
              "null",
              "string"
            ]
          },
          "twoFactorRecoveryCode": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "SignupDTO": {
        "required": [
          "email",
          "password",
          "firstName",
          "lastName",
          "username"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "username": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Auth"
    },
    {
      "name": "Game"
    }
  ]
}